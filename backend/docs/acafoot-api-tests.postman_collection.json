          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Groupe A\",\n  \"categorie_id\": {{categorie_id}},\n  \"coach_id\": {{coach_id}}\n}"
            },
            "url": "{{base_url}}/api/admin/groupes"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "if (json?.data?.groupe?.id) { pm.collectionVariables.set('groupe_id', json.data.groupe.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/admin/joueurs",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Joueur\",\n  \"prenom\": \"Test\",\n  \"date_naissance\": \"2014-05-10\",\n  \"parent_id\": {{parent_id}},\n  \"categorie_id\": {{categorie_id}}\n}"
            },
            "url": "{{base_url}}/api/admin/joueurs"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "if (json?.data?.joueur?.id) { pm.collectionVariables.set('joueur_id', json.data.joueur.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/admin/groupes/{groupe}/assign-coach",
          "request": {
