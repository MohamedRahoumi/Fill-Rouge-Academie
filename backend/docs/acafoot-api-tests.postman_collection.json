    {
      "name": "05 - Admin Paiements et Notifications",
      "item": [
        {
          "name": "GET /api/admin/paiements",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" }
            ],
            "url": "{{base_url}}/api/admin/paiements"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "const first = json?.data?.paiements?.data?.[0];",
                  "if (first?.id) { pm.collectionVariables.set('paiement_id', first.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/admin/paiements/{paiement}/valider",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" }
            ],
            "url": "{{base_url}}/api/admin/paiements/{{paiement_id}}/valider"
          }
        },
        {
          "name": "POST /api/notifications/read-all",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" }
            ],
            "url": "{{base_url}}/api/notifications/read-all"
          }
        },
        {
          "name": "POST /api/notifications/{notification}/read",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" }
            ],
            "url": "{{base_url}}/api/notifications/{{notification_id}}/read"
          }
        }
      ]
    },
    {
      "name": "99 - Logout",
      "item": [
        {
          "name": "POST /api/auth/logout (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" }
            ],
            "url": "{{base_url}}/api/auth/logout"
          },
          "event": [
